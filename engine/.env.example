# Monday engine config — copy to engine/.env and fill in. NEVER commit .env (gitignored).
# All credentials live engine-side; agents never see them (invariants 1–2).

# --- data-source credentials ---
# FINMIND_TOKEN is REQUIRED in production: it's the primary real source (prices + 法人/margin chips +
# sector) and lifts the free-tier rate limit so a wide universe can backfill. Register at finmindtrade.com.
FINMIND_TOKEN=
# CMONEY_USER=
# CMONEY_PASSWORD=

# --- outbound evva swarm webhook (token-free on the swarm side, invariant 8a) ---
# EVVA_WEBHOOK_URL=http://127.0.0.1:8888/api/swarm/monday/event

# --- Telegram (User-facing, invariant 8b; both blank → disabled / no-op) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- server / local state ---
# MONDAY_HOST=127.0.0.1
# MONDAY_PORT=7790
# SQLITE_PATH=monday.db
# DATA_DIR=data
